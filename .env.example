# ==================================================
# GitLens AI - Root Environment Variables
# ==================================================
# Copy the required values into the corresponding
# backend/.env and frontend/frontend/.env files.
#
# This file is only documentation.
# Do NOT rename it to .env.
# ==================================================


# ==================================================
# Backend
# File: backend/.env
# ==================================================

MONGODB_URL=mongodb://mongodb:27017/gitlens_ai
GITHUB_TOKEN=your_github_personal_access_token
DATABASE_NAME=gitlens_ai


# ==================================================
# Frontend
# File: frontend/frontend/.env
# ==================================================

VITE_API_URL=http://localhost:8000